# SEO MCP PRO - Environment Configuration

# ============================================
# SEO MCP PRO License (Pro features)
# ============================================
# License key for Pro tier (reports, dashboard, credential store)
# Format: SMCP-XXXX-XXXX-XXXX-XXXX
# Get yours at https://github.com/bypixels/SEO-MCP-PRO
SEO_MCP_PRO_KEY=

# ============================================
# Google OAuth 2.0 (for user-specific access)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=

# ============================================
# Google Service Account (for server-to-server)
# ============================================
# Path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
# Email to impersonate for domain-wide delegation (optional)
GOOGLE_SERVICE_ACCOUNT_IMPERSONATE=

# ============================================
# Google API Keys (for public APIs)
# ============================================
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# ============================================
# Google Ads
# ============================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ============================================
# Cloudflare
# ============================================
CLOUDFLARE_API_TOKEN=
# Legacy auth (if not using API token)
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# ============================================
# External Services
# ============================================
SSL_LABS_API_ENDPOINT=https://api.ssllabs.com/api/v3

# Urlbox (for screenshot tool, optional)
URLBOX_API_KEY=
URLBOX_API_SECRET=

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
LOG_LEVEL=info
CACHE_TTL=300
CACHE_MAX_ITEMS=1000
CACHE_DIRECTORY=

# Rate limiting
RATE_LIMIT_ENABLED=true

# ============================================
# Dashboard (Web UI)
# ============================================
DASHBOARD_ENABLED=false
DASHBOARD_PORT=3737
DASHBOARD_API_KEY=
DASHBOARD_AUTH_REQUIRED=true

# ============================================
# Credential Store (encrypted persistence)
# ============================================
# Custom encryption key (falls back to DASHBOARD_API_KEY or machine-derived key)
CREDENTIAL_ENCRYPTION_KEY=
# Custom storage path (defaults to project root)
CREDENTIAL_STORE_PATH=
